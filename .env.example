# SERVER CORE
PORT=3000
NODE_ENV=development
NODE_ID=node-1

# DATABASE
MONGO_URI=mongodb://localhost:27017/ideaxchange
REDIS_URL=redis://localhost:6379

# CRYPTOGRAPHIC SECRETS (Min 32 chars)
PLATFORM_SIGNING_KEY=your-secure-hmac-sha256-signing-key-here-32-chars
RAFT_INTERNAL_SECRET=your-secure-raft-internal-auth-secret-here-32-chars
JWT_SECRET=your-secure-jwt-asymmetric-or-symmetric-key-here-32-chars

# SECURITY POLICIES
CORS_ORIGIN=http://localhost:3000
COOKIE_DOMAIN=localhost
KEY_VERSION=v1

# PLATFORM AI (GEMINI)
GEMINI_API_KEY=your-gemini-ai-studio-api-key-here

# GOOGLE OAUTH
OAUTH_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
